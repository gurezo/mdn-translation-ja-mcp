{
  "name": "mdn-translation-ja-mcp",
  "version": "1.0.0",
  "description": "MDN Web Docs Japanese Translation MCP Server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-glossary-data.mjs && node scripts/copy-rules-data.mjs",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "docs:clean": "rm -rf docs/.nojekyll docs/assets docs/functions docs/hierarchy.html docs/index.html docs/media docs/modules docs/modules.html docs/types docs/variables",
    "docs:build": "npm run docs:clean && typedoc --options typedoc.json",
    "docs:publish": "npm run docs:build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "vitest run src/e2e",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "gh-pages": "^6.3.0",
    "prettier": "^3.8.1",
    "typedoc": "^0.28.18",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
