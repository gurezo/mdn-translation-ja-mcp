{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gurezo/mdn-translation-ja-mcp/rules/mozilla-glossary-excerpt.schema.json",
  "title": "Mozilla L10N glossary excerpt for review",
  "description": "Wiki 用語集の一部をレビュー参照用に保持する（{{glossary}} マクロ置換用の glossary-terms.json とは別）。",
  "type": "object",
  "required": ["sourceUrl", "retrievedAt", "terms"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "任意。エディタ用 JSON Schema の場所。"
    },
    "sourceUrl": {
      "type": "string",
      "format": "uri",
      "description": "Mozilla L10N 用語集（Wiki）の URL"
    },
    "retrievedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "参照日（ISO 8601 日付）"
    },
    "description": {
      "type": "string",
      "description": "このファイルの役割の補足（任意）"
    },
    "terms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "en", "ja"],
        "additionalProperties": false,
        "properties": {
          "slug": {
            "type": "string",
            "description": "用語スラグ（{{glossary(\"slug\")}} と一致）"
          },
          "en": { "type": "string", "description": "英語表記の目安" },
          "ja": {
            "type": "string",
            "description": "日本語訳の目安（レビュー時の参照）"
          },
          "note": { "type": "string", "description": "補足（任意）" }
        }
      }
    }
  }
}
