{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gurezo/mdn-translation-ja-mcp/rules/prohibited-expressions.schema.json",
  "title": "Prohibited expressions for Japanese MDN translation review",
  "description": "本文（コードフェンス外）で検出したい禁止表現・注意表現のリスト。",
  "type": "object",
  "required": ["sourceUrl", "retrievedAt", "items"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "sourceUrl": {
      "type": "string",
      "format": "uri",
      "description": "ルールの根拠となるガイドライン等の URL"
    },
    "retrievedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "description": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "matchType", "pattern", "severity", "message"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "matchType": {
            "type": "string",
            "enum": ["literal", "regex"]
          },
          "pattern": {
            "type": "string",
            "description": "literal のときは部分一致、regex のときは行単位で検証する正規表現"
          },
          "severity": {
            "type": "string",
            "enum": ["error", "warning", "info"]
          },
          "message": { "type": "string" }
        }
      }
    }
  }
}
