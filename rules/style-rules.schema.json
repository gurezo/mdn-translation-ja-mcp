{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gurezo/mdn-translation-ja-mcp/rules/style-rules.schema.json",
  "title": "Japanese style rules excerpt for review",
  "description": "文体・表記の最小ルールセット（参照用）。機械チェックは review-translation と組み合わせて段階的に拡張する。",
  "type": "object",
  "required": ["sourceUrl", "retrievedAt", "rules"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "sourceUrl": {
      "type": "string",
      "format": "uri",
      "description": "文体表などの参照 URL"
    },
    "retrievedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "description": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "message"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["error", "warning", "info"]
          },
          "message": { "type": "string" },
          "pattern": {
            "type": "string",
            "description": "将来の自動検査用の正規表現（任意）"
          },
          "implementationNote": {
            "type": "string",
            "description": "実装との対応メモ（任意）"
          }
        }
      }
    }
  }
}
